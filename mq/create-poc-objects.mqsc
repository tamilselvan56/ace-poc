ALTER QMGR DEADQ(SYSTEM.DEAD.LETTER.QUEUE)

DEFINE QLOCAL(ACE.POC.INPUT) REPLACE DEFPSIST(YES)
DEFINE QLOCAL(ACE.POC.OUTPUT) REPLACE DEFPSIST(YES)

DEFINE QLOCAL(DLQ.TRANSIENT.ACE.POC) REPLACE DEFPSIST(YES)
DEFINE QLOCAL(DLQ.PERMANENT.ACE.POC) REPLACE DEFPSIST(YES)

DEFINE TOPIC(ACE.POC.EVENTS) REPLACE TOPICSTR('ace/poc/events')

DISPLAY QMGR DEADQ
DISPLAY QLOCAL(ACE.POC.*)
DISPLAY QLOCAL(DLQ.TRANSIENT.ACE.POC)
DISPLAY QLOCAL(DLQ.PERMANENT.ACE.POC)
DISPLAY TOPIC(ACE.POC.EVENTS)

END