pipeline {
    agent { label 'windows-ace' }
    options {
        skipDefaultCheckout(true)
    }
    environment {
        ACE_PROJECT    = 'ace-poc-app'
        ACE_WORKSPACE  = "${WORKSPACE}\\workspace"
        BAR_DIR        = "${WORKSPACE}\\bars"
        BAR_FILE       = "${WORKSPACE}\\bars\\ace-poc-app_${BUILD_NUMBER}.bar"
        ACE_PROFILE    = 'C:\\Program Files\\IBM\\ACE\\13.0.7.0\\server\\bin\\mqsiprofile.cmd'
        ACE_HOST       = 'localhost'
        ACE_ADMIN_PORT = '7600'
        ACE_HTTP_PORT  = '7800'
        MQ_QMGR        = 'ACEPOCQM'
    }

    stages {

        // ── Stage 1: Checkout ─────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ── Stage 2: Verify ACE CLI ───────────────────────────────────────
        stage('Verify ACE CLI') {
            steps {
                bat '''
                    call "%ACE_PROFILE%"
                    where ibmint
                    ibmint --help
                '''
            }
        }

        // ── Stage 3: Verify ACE Server Running ────────────────────────────
        stage('Verify Server') {
            steps {
                echo 'Checking ACE integration server is up...'
                bat '''
                    curl -k -s ^
                        -o server_status.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        https://%ACE_HOST%:%ACE_ADMIN_PORT%/apiv2/applications
                    echo.
                    echo === Server Status ===
                    type server_status.json
                '''
            }
        }

        // ── Stage 4: Verify MQ Queues ─────────────────────────────────────
        stage('Verify MQ Queues') {
            steps {
                echo 'Checking MQ queue depths before deployment...'
                bat '''
                    call "%ACE_PROFILE%"
                    echo === PRE-DEPLOY QUEUE DEPTHS ===
                    echo DISPLAY QLOCAL(ACE.POC.GENERAL.EVENTS) CURDEPTH | runmqsc %MQ_QMGR%
                    echo DISPLAY QLOCAL(DLQ.TRANSIENT.ACE.POC)  CURDEPTH | runmqsc %MQ_QMGR%
                    echo DISPLAY QLOCAL(DLQ.PERMANENT.ACE.POC)  CURDEPTH | runmqsc %MQ_QMGR%
                '''
            }
        }

        // ── Stage 5: Package BAR ──────────────────────────────────────────
        stage('Package BAR') {
            steps {
                bat '''
                    call "%ACE_PROFILE%"
                    if not exist "%BAR_DIR%" mkdir "%BAR_DIR%"
                    ibmint package ^
                        --input-path "%ACE_WORKSPACE%" ^
                        --output-bar-file "%BAR_FILE%" ^
                        --project "%ACE_PROJECT%"
                    echo.
                    echo === BAR Created ===
                    dir "%BAR_FILE%"
                '''
            }
        }

        // ── Stage 6: Deploy BAR ───────────────────────────────────────────
        stage('Deploy BAR') {
            steps {
                echo "Deploying to ACEPOCSERVER..."
                bat '''
                    call "%ACE_PROFILE%"
                    mqsideploy -i %ACE_HOST% -p %ACE_ADMIN_PORT% --https ^
                        -a "%BAR_FILE%" ^
                        -w 300
                '''
            }
        }

        // ── Stage 7: Wait for Flows to Start ─────────────────────────────
        stage('Wait for Deploy') {
            steps {
                echo 'Waiting 15 seconds for flows to initialize...'
                bat 'ping -n 16 127.0.0.1 > nul'
            }
        }

        // ── Stage 8: Smoke Test - Health Check ────────────────────────────
        stage('Smoke Test - Health Check') {
            steps {
                echo 'Testing HealthCheck flow - expect 200...'
                bat '''
                    curl -s ^
                        -o health_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/health
                    echo.
                    echo === Health Check Response ===
                    type health_response.json
                '''
            }
        }

        // ── Stage 9: Smoke Test - Audit Happy Path ────────────────────────
        stage('Smoke Test - Audit Happy Path') {
            steps {
                echo 'Testing AuditLog valid payload - expect 202...'
                bat '''
                    echo {"eventType":"SMOKE_TEST","sourceSystem":"JENKINS-CI","userId":"CI-USR-001","action":"CREATE","resourceId":"CI-RES-%BUILD_NUMBER%","resourceType":"TEST"} > audit_payload.json
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -H "X-Correlation-ID: JENKINS-CI-%BUILD_NUMBER%" ^
                        -d @audit_payload.json ^
                        -o audit_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === Audit Log Response ===
                    type audit_response.json
                '''
            }
        }

        // ── Stage 10: Smoke Test - Validation Error ───────────────────────
        stage('Smoke Test - Validation Error') {
            steps {
                echo 'Testing missing eventType - expect 400 ERR_AUD_002...'
                bat '''
                    echo {"sourceSystem":"JENKINS-CI","userId":"CI-USR-001","action":"CREATE","resourceId":"CI-RES-001","resourceType":"TEST"} > validation_payload.json
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -d @validation_payload.json ^
                        -o validation_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === Validation Error Response ===
                    type validation_response.json
                '''
            }
        }

        // ── Stage 11: Smoke Test - DLQ Routing ───────────────────────────
        stage('Smoke Test - DLQ Routing') {
            steps {
                echo 'Disabling main queue to force DLQ routing - expect 500...'
                bat '''
                    call "%ACE_PROFILE%"
                    echo ALTER QLOCAL(ACE.POC.GENERAL.EVENTS) PUT(DISABLED) | runmqsc %MQ_QMGR%
                    ping -n 4 127.0.0.1 > nul

                    echo {"eventType":"DLQ_TEST","sourceSystem":"JENKINS-CI","userId":"CI-USR-001","action":"CREATE","resourceId":"DLQ-RES-001","resourceType":"TEST"} > dlq_payload.json
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -d @dlq_payload.json ^
                        -o dlq_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === DLQ Response ===
                    type dlq_response.json

                    echo ALTER QLOCAL(ACE.POC.GENERAL.EVENTS) PUT(ENABLED) | runmqsc %MQ_QMGR%
                    echo.
                    echo === TRANSIENT DLQ depth after test ===
                    echo DISPLAY QLOCAL(DLQ.TRANSIENT.ACE.POC) CURDEPTH | runmqsc %MQ_QMGR%
                '''
            }
        }

        // ── Stage 12: Smoke Test - OAuth Token Generation ────────────────
        stage('Smoke Test - OAuth Token') {
            steps {
                echo 'Testing OAuth2 token generation - expect 200...'
                bat '''
                    echo {"grant_type":"client_credentials","client_id":"jenkins-ci-client","client_secret":"jenkins-ci-secret-2024","scope":"audit:write"} > oauth_payload.json

                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -d @oauth_payload.json ^
                        -o oauth_token_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/oauth/token
                    echo.
                    echo === OAuth Token Response ===
                    type oauth_token_response.json
                '''
            }
        }

        // ── Stage 13: Extract Token for Next Stages ───────────────────────
        stage('Extract Access Token') {
            steps {
                echo 'Extracting access_token from OAuth response...'
                script {
                    def tokenJson = readFile('oauth_token_response.json')
                    def matcher = (tokenJson =~ /"access_token"\s*:\s*"([^"]+)"/)
                    if (matcher.find()) {
                        env.ACCESS_TOKEN = matcher.group(1)
                        echo "Token extracted successfully"
                    } else {
                        error "Failed to extract access_token from response"
                    }
                }
            }
        }

        // ── Stage 14: Smoke Test - Audit Log WITHOUT Token ────────────────
        stage('Smoke Test - No Token (Expect 401)') {
            steps {
                echo 'Testing AuditLog without Authorization header - expect 401...'
                bat '''
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -d @audit_payload.json ^
                        -o no_token_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === No Token Response ===
                    type no_token_response.json
                '''
            }
        }

        // ── Stage 15: Smoke Test - Audit Log WITH Invalid Token ───────────
        stage('Smoke Test - Invalid Token (Expect 401)') {
            steps {
                echo 'Testing AuditLog with invalid token - expect 401...'
                bat '''
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -H "Authorization: Bearer invalid.token.here" ^
                        -d @audit_payload.json ^
                        -o invalid_token_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === Invalid Token Response ===
                    type invalid_token_response.json
                '''
            }
        }

        // ── Stage 16: Smoke Test - Audit Log WITH Valid Token ─────────────
        stage('Smoke Test - Authenticated Audit Log (Expect 202)') {
            steps {
                echo 'Testing AuditLog with valid Bearer token - expect 202...'
                bat '''
                    curl -s ^
                        -X POST ^
                        -H "Content-Type: application/json" ^
                        -H "Authorization: Bearer %ACCESS_TOKEN%" ^
                        -H "X-Correlation-ID: JENKINS-AUTH-%BUILD_NUMBER%" ^
                        -d @audit_payload.json ^
                        -o authenticated_response.json ^
                        -w "HTTP_STATUS:%%{http_code}" ^
                        http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    echo.
                    echo === Authenticated Response ===
                    type authenticated_response.json
                '''
            }
        }

        // ── Stage 17: Smoke Test - Rate Limiting ──────────────────────────
        stage('Smoke Test - Rate Limit (Expect 429 on burst)') {
            steps {
                echo 'Sending 11 rapid requests to trigger rate limit...'
                bat '''
                    for /L %%i in (1,1,11) do (
                        curl -s -X POST ^
                            -H "Content-Type: application/json" ^
                            -H "Authorization: Bearer %ACCESS_TOKEN%" ^
                            -d @audit_payload.json ^
                            -o rate_limit_response_%%i.json ^
                            -w "Request %%i: HTTP_STATUS:%%{http_code}\\n" ^
                            http://%ACE_HOST%:%ACE_HTTP_PORT%/api/v1/audit/log
                    )
                    echo.
                    echo === Last Request Response (should be 429) ===
                    type rate_limit_response_11.json
                '''
            }
        }

        // ── Stage 18: Post Deploy Queue Report ───────────────────────────
        stage('Post Deploy - Queue Report') {
            steps {
                echo 'Final queue depth report...'
                bat '''
                    call "%ACE_PROFILE%"
                    echo ===== FINAL QUEUE DEPTH REPORT =====
                    echo DISPLAY QLOCAL(ACE.POC.GENERAL.EVENTS) CURDEPTH | runmqsc %MQ_QMGR%
                    echo DISPLAY QLOCAL(DLQ.TRANSIENT.ACE.POC)  CURDEPTH | runmqsc %MQ_QMGR%
                    echo DISPLAY QLOCAL(DLQ.PERMANENT.ACE.POC)  CURDEPTH | runmqsc %MQ_QMGR%
                    echo =====================================
                '''
            }
        }

    }

    // ── Post Actions ──────────────────────────────────────────────────────
    post {
        success {
            archiveArtifacts artifacts: [
                'bars/*.bar',
                'health_response.json',
                'audit_response.json',
                'validation_response.json',
                'dlq_response.json',
                'server_status.json',
                'oauth_token_response.json',
                'no_token_response.json',
                'invalid_token_response.json',
                'authenticated_response.json',
                'rate_limit_response_*.json'
            ].join(','), allowEmptyArchive: true, fingerprint: true

            echo '''
            =========================================
             ACE POC PIPELINE - SUCCESS
            =========================================
             BAR packaged, deployed and smoke tested.
             Auth, retry, DLQ and rate limit verified.
            =========================================
            '''
        }
        failure {
            echo 'Pipeline failed. Check the Console Output for BIP error codes.'
            bat '''
                call "C:\\Program Files\\IBM\\ACE\\13.0.7.0\\server\\bin\\mqsiprofile.cmd"
                echo Restoring MQ queue after failure...
                echo ALTER QLOCAL(ACE.POC.GENERAL.EVENTS) PUT(ENABLED) | runmqsc ACEPOCQM
            '''
        }
        always {
            echo "Build #${BUILD_NUMBER} finished. Check Artifacts tab for response files."
        }
    }
}